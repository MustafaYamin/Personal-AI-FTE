# =============================================================================
# Personal AI FTE - .gitignore
# =============================================================================
# This file ensures sensitive credentials and temporary files are never
# committed to GitHub. DO NOT REMOVE OR MODIFY THESE RULES!
# =============================================================================

# -----------------------------------------------------------------------------
# 🔒 CRITICAL: AI Employee Secrets (NEVER COMMIT THESE)
# -----------------------------------------------------------------------------

# Gmail API credentials and OAuth tokens
.cache/
gmail_credentials.json
gmail_token.pickle
*.pickle

# WhatsApp session data
whatsapp_session/
**/whatsapp_session/**

# Any credential files
*.credentials
*.secret
credentials.json

# Environment files with API keys
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# 📝 Logs and Activity Data (May Contain Sensitive Information)
# -----------------------------------------------------------------------------

# Application logs (may contain email content, personal data)
AI_Employee_Vault/Logs/
**/Logs/*.log
**/Logs/*.md
*.log

# Processed file tracking (local state only)
filesystem_processed.txt
gmail_processed.txt
whatsapp_processed.txt

# -----------------------------------------------------------------------------
# 🐍 Python
# -----------------------------------------------------------------------------

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# C extensions
*.c
*.cpp
*.obj
*.o

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# -----------------------------------------------------------------------------
